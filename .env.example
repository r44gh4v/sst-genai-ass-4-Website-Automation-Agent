# ── Nvidia NIM API credentials ──────────────────────────────────────────────
# Get a free key at https://build.nvidia.com (nvapi- prefix, no credit card).
NIM_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Reasoning model (the "brain") ────────────────────────────────────────────
# Drives the tool-use loop, so it MUST support OpenAI-style function/tool calling.
# Default: meta/llama-3.3-70b-instruct - the NIM family with AUTOMATIC, unconditional
# tool calling; proven for long multi-tool agent loops. Safe default for a live demo.
#
# Stronger tool-calling alternatives on NIM (all free tier):
#   nvidia/llama-3.3-nemotron-super-49b-v1.5  (NVIDIA's flagship agentic model;
#                                              keep reasoning/"detailed thinking" OFF)
#   qwen/qwen3-235b-a22b                       (top open agentic / tool use)
#   moonshotai/kimi-k2-instruct-0905           (strong autonomous tool calling)
#   deepseek-ai/deepseek-v3.1                  (strict function calling, non-thinking)
#
# Single MULTIMODAL brain (vision + tools in ONE model - only two exist on NIM):
#   meta/llama-4-scout-17b-16e-instruct
#   mistralai/mistral-small-3.2-24b-instruct-2506
MODEL=meta/llama-3.3-70b-instruct

# ── Vision model (the "eyes") ────────────────────────────────────────────────
# Used by the analyze_screen tool to interpret screenshots. It only needs image
# input (no tool calling), so the strongest pure VLM is best.
# Default: meta/llama-3.2-90b-vision-instruct. Alt: mistralai/mistral-small-3.2-24b-instruct-2506
VISION_MODEL=meta/llama-3.2-90b-vision-instruct
# Set to false to disable the vision tool entirely (DOM + screenshots only).
VISION_ENABLED=true

# Sampling temperature for the brain (low = more deterministic / on-task).
TEMPERATURE=0.2

# ── Browser ──────────────────────────────────────────────────────────────────
# "true" hides the window; default (false) shows the browser so you can watch live.
HEADLESS=false

# Agent loop safety cap (max LLM tool-use iterations per task).
MAX_ITERATIONS=30

# Local web UI port.
PORT=3000
