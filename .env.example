# Nvidia NIM API credentials
NIM_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use (MUST support OpenAI-style function/tool calling).
# meta/llama-3.3-70b-instruct is recommended: strong, reliable tool calling on NIM.
# Other good options: nvidia/llama-3.1-nemotron-70b-instruct, meta/llama-3.1-70b-instruct
MODEL=meta/llama-3.3-70b-instruct

# Browser: set to "true" to hide the window. Default (false) shows the browser so
# you can watch the agent work live.
HEADLESS=false

# Agent loop safety cap (max LLM tool-use iterations per task)
MAX_ITERATIONS=25

# Local web UI port
PORT=3000
